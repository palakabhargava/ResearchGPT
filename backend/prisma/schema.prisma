datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                 String            @id @default(uuid())
  email              String            @unique
  passwordHash       String
  subscriptionStatus String            @default("FREE") // FREE, PRO, ENTERPRISE
  createdAt          DateTime          @default(now())
  sessions           ResearchSession[]
  savedReports       SavedReport[]
}

model ResearchSession {
  id                    String         @id @default(uuid())
  userId                String
  user                  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  query                 String
  status                String         @default("STARTED") // STARTED, SEARCHING, VERIFYING, FACTCHECKING, SUMMARIZING, REPORTING, COMPLETED, FAILED
  confidenceScore       Int            @default(0)
  report                String         @default("")
  summary               String         @default("")
  answer                String         @default("")
  supportingEvidence    Json           @default("[]") // JSON list of items
  contradictoryEvidence Json           @default("[]") // JSON list of items
  createdAt             DateTime       @default(now())
  steps                 ResearchStep[]
  findings              Finding[]
  sources               Source[]
  images                Image[]
  savedReports          SavedReport[]
}

model ResearchStep {
  id         String          @id @default(uuid())
  sessionId  String
  session    ResearchSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  agentName  String // SEARCH, VERIFICATION, FACT_CHECKER, SUMMARIZER, REPORT_GENERATOR
  title      String
  message    String          @default("")
  status     String          @default("PENDING") // PENDING, RUNNING, COMPLETED, FAILED
  createdAt  DateTime        @default(now())
}

model Finding {
  id         String          @id @default(uuid())
  sessionId  String
  session    ResearchSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  url        String
  title      String          @default("")
  description String          @default("")
  markdown   String          @default("")
  createdAt  DateTime        @default(now())
}

model Source {
  id            String          @id @default(uuid())
  sessionId     String
  session       ResearchSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  url           String
  title         String          @default("")
  description   String          @default("")
  relevance     String          @default("medium") // high, medium, low
  screenshotUrl String          @default("")
  faviconUrl    String          @default("")
  createdAt     DateTime        @default(now())
}

model Image {
  id        String          @id @default(uuid())
  sessionId String
  session   ResearchSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  url       String          @default("")
  src       String
  type      String          @default("url") // url, html, base64
  alt       String          @default("")
  width     Int?
  height    Int?
  category  String          @default("other")
  createdAt DateTime        @default(now())
}

model SavedReport {
  id        String          @id @default(uuid())
  userId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId String
  session   ResearchSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  title     String
  summary   String
  report    String
  createdAt DateTime        @default(now())
}
